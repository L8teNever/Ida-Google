# Kopieren nach ".env" und ausfuellen. ".env" NIEMALS committen.

# --- Google OAuth-Client ---
# In der Google Cloud Console (console.cloud.google.com) einmalig einrichten:
#   1. Neues Projekt anlegen (oder ein bestehendes benutzen).
#   2. "APIs & Dienste" -> "OAuth-Zustimmungsbildschirm" -> Nutzertyp
#      "Extern" (auch fuer ein privates Google-Konto), App-Name/Support-Mail
#      ausfuellen. Testnutzer: deine eigene Google-Mail-Adresse eintragen --
#      dann ist die App sofort nutzbar, auch ohne Google-Verifizierung
#      (die "unverified app"-Warnung beim Anmelden ist normal und erwartet,
#      es ist ja deine eigene App fuer dich selbst).
#   3. Fuer jeden Google-Dienst, den du nutzen willst, die passende API unter
#      "APIs & Dienste" -> "Bibliothek" aktivieren -- aktuell noetig: "Google
#      Tasks API", "People API", "Google Calendar API", "Gmail API",
#      "Google Keep API".
#   4. "APIs & Dienste" -> "Anmeldedaten" -> "Anmeldedaten erstellen" ->
#      "OAuth-Client-ID" -> Typ "Webanwendung".
#   5. Bei "Autorisierte Weiterleitungs-URIs" GENAU die URL eintragen, die
#      unten bei GOOGLE_REDIRECT_URI steht (muss 1:1 uebereinstimmen).
#   6. Client-ID und Client-Secret von dort hierher kopieren.
GOOGLE_CLIENT_ID=hier-client-id-eintragen
GOOGLE_CLIENT_SECRET=hier-client-secret-eintragen

# Die oeffentliche Callback-URL fuer den Auth-Port -- deine eigene Domain
# plus /oauth/callback. Muss exakt (inkl. https, ohne trailing slash) mit
# Schritt 5 oben uebereinstimmen.
GOOGLE_REDIRECT_URI=https://google-auth.deine-domain.de/oauth/callback

# --- Absicherung ---
# MCP_AUTH_TOKEN: fuer den MCP-Port (die eigentlichen Google-Werkzeuge).
# AUTH_TOKEN: fuer den Auth-Port (/authorize) -- zusaetzliches, kostenloses
# Sicherheitsnetz. Die eigentliche Absicherung dieses Ports soll aber
# Cloudflare Zero Trust Access sein (siehe README) -- nur du solltest
# /authorize je aufrufen koennen, sonst kann jemand anders sein eigenes
# Google-Konto verbinden und deins damit ueberschreiben.
# Beide erzeugen z.B. mit: openssl rand -hex 32
MCP_AUTH_TOKEN=hier-langes-zufaelliges-token-eintragen
AUTH_TOKEN=hier-ein-zweites-langes-zufaelliges-token-eintragen

# Lokale Ports, die docker-compose auf 127.0.0.1 published (siehe docker-compose.yml).
# Standard 4569/4570, damit es neben Ida-Untis (8000), Ida-Telegram (4567)
# und Ida-Memory (4568) auf demselben Server laufen kann.
MCP_PORT=4569
AUTH_PORT=4570

# --- Nur fuer docker-compose (Image-Referenz aus GHCR) ---
# Dein GitHub-Benutzername/-Organisation in Kleinbuchstaben.
GITHUB_OWNER=l8tenever
IMAGE_TAG=latest
